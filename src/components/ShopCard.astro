---
import type { Artwork } from "../data/artworks";
import {
  formatPrice,
  getAvailableProducts,
  getLowestAvailablePrice,
  hasAvailableProductType,
} from "../data/artworkHelpers";

const { artwork } = Astro.props as { artwork: Artwork };
const lowestPrice = getLowestAvailablePrice(artwork);
const hasAvailableOriginal = hasAvailableProductType(artwork, "original");
const availableProducts = getAvailableProducts(artwork);
const hasOnlyAvailableOriginal = availableProducts.length === 1 && availableProducts[0].type === "original";
const priceLabel = lowestPrice
  ? `${hasOnlyAvailableOriginal ? "" : "From "}${formatPrice(lowestPrice)}`
  : "View piece";
const compactSummary = availableProducts
  .map((product) => {
    if (product.type === "original" && artwork.dimensions) {
      return `Original · ${artwork.dimensions}`;
    }

    return product.label;
  })
  .filter((value, index, array) => array.indexOf(value) === index)
  .join(" · ");
---

<a href={`/collage/${artwork.slug}/`} class="shop-card">
  <div class="shop-card__image-wrap">
    {hasAvailableOriginal ? <span class="shop-card__badge">Original available</span> : null}
    <img
      src={artwork.thumbnail || artwork.image}
      alt={artwork.alt}
      class="shop-card__image"
      loading="lazy"
    />
  </div>

  <div class="shop-card__body">
    <div class="shop-card__meta">
      <span>{priceLabel}</span>
    </div>
    <h2 class="shop-card__title">{artwork.title}</h2>
    <p class="shop-card__summary">{compactSummary || "Not currently available"}</p>
    <span class="shop-card__cta">View piece</span>
  </div>
</a>
