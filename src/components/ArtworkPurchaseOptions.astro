---
import type { Artwork } from "../data/artworks";
const { artwork } = Astro.props as { artwork: Artwork };
// Render any purchase options that have a URL (assumed current offerings).
const available = artwork.purchaseOptions.filter((o) => o.url && o.label);
---

<div class="mt-6">
  {available.length === 0 ? (
    <p>This piece is not currently available.</p>
  ) : (
    <div class="flex gap-3 flex-wrap">
      {available.map((opt) => (
        <a class="px-3 py-2 bg-neutral-900 text-white text-sm rounded" href={opt.url} target="_blank" rel="noopener noreferrer">{opt.label}{opt.price ? ` — ${opt.price}` : ''}</a>
      ))}
    </div>
  )}
</div>
