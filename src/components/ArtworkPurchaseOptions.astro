---
import type { Artwork } from "../data/artworks";
import ProductOptionCard from "./ProductOptionCard.astro";
import { getAvailableProducts, getUnavailableProducts } from "../data/artworkHelpers";
const { artwork } = Astro.props as { artwork: Artwork };
const available = getAvailableProducts(artwork);
const unavailable = getUnavailableProducts(artwork);
const availableOriginals = available.filter((product) => product.type === "original");
const availableReproductions = available.filter((product) => product.type !== "original");
const hasMixedAvailableProducts = availableOriginals.length > 0 && availableReproductions.length > 0;
---

<div class="mt-6">
  {available.length === 0 ? (
    <p>This piece is not currently available.</p>
  ) : (
    <section class="purchase-panel">
      <div class="purchase-panel__intro">
        <p class="purchase-panel__copy">Originals are one-of-a-kind. Reproductions are printed in small batches and packaged with care.</p>
      </div>

      {availableOriginals.length > 0 ? (
        <div class="purchase-panel__group purchase-panel__group--original">
          {hasMixedAvailableProducts ? <p class="purchase-panel__group-label">Original Artwork</p> : null}
          <div class="product-options-grid">
            {availableOriginals.map((product) => (
              <ProductOptionCard artwork={artwork} product={product} />
            ))}
          </div>
        </div>
      ) : null}

      {availableReproductions.length > 0 ? (
        <div class="purchase-panel__group">
          {hasMixedAvailableProducts ? (
            <div class="purchase-panel__group-heading">
              <p class="purchase-panel__group-label">Reproductions</p>
              <p class="purchase-panel__group-description">Archival matte reproductions of the original collage, signed.</p>
            </div>
          ) : null}
          <div class="product-options-grid">
            {availableReproductions.map((product) => (
              <ProductOptionCard artwork={artwork} product={product} hideNote />
            ))}
          </div>
        </div>
      ) : null}

      <p class="purchase-panel__trust">Ships flat from Indianapolis. Packed with care.</p>
      <p class="commerce-note purchase-panel__handoff">Real Life Handoff is free for people I know in real life.</p>
    </section>
  )}

  {unavailable.length > 0 ? (
    <div class="product-options-grid mt-4">
      {unavailable.map((product) => (
        <ProductOptionCard artwork={artwork} product={product} />
      ))}
    </div>
  ) : null}
</div>
