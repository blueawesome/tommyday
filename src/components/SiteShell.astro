---
import SidebarNav from "../components/SidebarNav.astro";
import SiteFooter from "../components/SiteFooter.astro";

const isHomePage = Astro.url.pathname === "/";
const mobileLogo = isHomePage ? "/images/tommy-day-art-small.png" : "/images/tommy-day-logo.png";
const mobileLogoAlt = isHomePage ? "Tommy Day Art" : "Tommy Day";
---
  <div class:list={["site-shell min-h-screen md:grid md:grid-cols-[260px_1fr]", isHomePage && "site-shell--home"]}>
    <header class:list={["mobile-site-header md:hidden", isHomePage && "mobile-site-header--home"]}>
      <a href="/" class="mobile-site-header__logo-link">
        <img src={mobileLogo} alt={mobileLogoAlt} class="mobile-site-header__logo" />
      </a>

      <details class="mobile-site-menu">
        <summary class="mobile-site-menu__toggle" aria-label="Open navigation">
          <i class="fa-sharp fa-solid fa-bars-staggered" aria-hidden="true"></i>
          <span class="sr-only">Menu</span>
        </summary>

        <div class="mobile-site-menu__panel">
          <SidebarNav />
          <slot name="mobile-menu-extra" />
        </div>
      </details>
    </header>

    <aside class="site-sidebar bg-transparent md:sticky md:top-0 md:h-screen md:pt-8 md:pl-6">
      <SidebarNav />
      <slot name="sidebar-extra" />
    </aside>

    <main class="px-6 py-8">
      <slot />
      <SiteFooter />
    </main>
  </div>
