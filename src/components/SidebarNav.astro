---
---
<div class="max-w-[260px]">
  <a href="/" class="inline-block w-full">
    <img src="/images/td-logo.png" alt="Tommy Day" class="w-full h-auto block td-logo" />
    <span class="sr-only">Tommy Day</span>
  </a>

  <nav class="mt-8 sidebar-nav">
    <ul class="flex gap-4 md:flex-col">
      <li>
        <a class="flex items-center gap-3" href="/collage/">
          <i class="fa-sharp fa-solid fa-scissors nav-icon" aria-hidden="true"></i>
          <span class="sr-only">Collage</span>
          <span class="nav-label">Collage</span>
        </a>
      </li>
      <li>
        <a class="flex items-center gap-3" href="/music/">
          <i class="fa-sharp fa-solid fa-guitar-electric nav-icon" aria-hidden="true"></i>
          <span class="sr-only">Music</span>
          <span class="nav-label">Music</span>
        </a>
      </li>
      <li>
        <a class="flex items-center gap-3" href="/video/">
          <i class="fa-sharp fa-solid fa-camcorder nav-icon" aria-hidden="true"></i>
          <span class="sr-only">Video</span>
          <span class="nav-label">Video</span>
        </a>
      </li>
      <li>
        <a class="flex items-center gap-3" href="/blog/">
          <i class="fa-sharp fa-solid fa-book-open nav-icon" aria-hidden="true"></i>
          <span class="sr-only">Blog</span>
          <span class="nav-label">Blog</span>
        </a>
      </li>
      <li>
        <a class="flex items-center gap-3" href="/contact/">
          <i class="fa-sharp fa-regular fa-paper-plane nav-icon" aria-hidden="true"></i>
          <span class="sr-only">Contact</span>
          <span class="nav-label">Contact</span>
        </a>
      </li>
    </ul>
  </nav>
</div>
