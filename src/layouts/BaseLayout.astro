---
import "../styles/global.css";
import Snipcart from "../components/Snipcart.astro";
import artFiltersScript from "../scripts/artFilters.js?url";
import shopFiltersScript from "../scripts/shopFilters.js?url";
import preorderLightboxScript from "../scripts/preorderLightbox.js?url";
const {
  title = "Tommy Day",
  description = "Analog collage, prints, cards, and strange paper goods by Tommy Day.",
  ogImage,
  ogType = "website",
  canonicalUrl,
  canonical,
  robots = "index,follow",
} = Astro.props;

const siteOrigin = "https://tommyday.com";
const resolvedCanonical = canonicalUrl || canonical;
const canonicalHref = resolvedCanonical
  ? new URL(resolvedCanonical, siteOrigin).href
  : undefined;
const ogImageHref = ogImage ? new URL(ogImage, siteOrigin).href : undefined;
const siteSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "url": siteOrigin,
      "name": "Tommy Day Art",
      "description": description
    },
    {
      "@type": "Person",
      "name": "Tommy Day",
      "url": siteOrigin,
      "sameAs": ["https://www.instagram.com/tommyday"]
    }
  ]
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonicalHref ? <link rel="canonical" href={canonicalHref} /> : null}
  <meta name="robots" content={robots} />
  <meta name="theme-color" content="#fff12f" />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Tommy Day Art" />
  {canonicalHref ? <meta property="og:url" content={canonicalHref} /> : null}
  {ogImageHref ? <meta property="og:image" content={ogImageHref} /> : null}
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImageHref ? <meta name="twitter:image" content={ogImageHref} /> : null}
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,600;1,400&family=Special+Elite&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
  <!-- Font Awesome kit (loads icons for the nav) -->
  <script src="https://kit.fontawesome.com/f0d3128641.js" crossorigin="anonymous"></script>
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-9V2CC0M35T"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){window.dataLayer.push(arguments);}
    window.gtag = gtag;
    gtag('js', new Date());
    gtag('config', 'G-9V2CC0M35T');
  </script>
    <!-- Structured data: WebSite and Person -->
    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
    <link rel="icon" href="/favicon.svg" />
    <!-- Load Alpine helpers as an ES module from src so Vite can bundle and HMR during dev -->
    <script type="module" src={artFiltersScript}></script>
    <script type="module" src={shopFiltersScript}></script>
    <script type="module" src={preorderLightboxScript}></script>
    <Snipcart />
  </head>
  <body class="bg-stone-100 text-neutral-950 antialiased">
    <slot />
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').then((reg) => {
          if (reg && reg.waiting) {
            // show update available
            showSWUpdate();
          }
          reg.addEventListener('updatefound', () => {
            const installing = reg.installing;
            if (!installing) return;
            installing.addEventListener('statechange', (evt) => {
              const s = evt && evt.target && (evt.target as any).state ? (evt.target as any).state : null;
              if (s === 'installed' && navigator.serviceWorker.controller) {
                showSWUpdate();
              }
            });
          });
        }).catch(() => {
          // ignore registration errors
        });
      }
      
      function showSWUpdate() {
        if (document.getElementById('sw-update')) return;
        const el = document.createElement('div');
        el.id = 'sw-update';
        el.className = 'sw-update';
        el.innerHTML = 'New version available.' +
          '<button id="sw-reload">Reload</button>' +
          '<button id="sw-dismiss">Dismiss</button>';
        document.body.appendChild(el);
        const reloadBtn = document.getElementById('sw-reload');
        const dismissBtn = document.getElementById('sw-dismiss');
        if (reloadBtn) {
          reloadBtn.addEventListener('click', () => {
            navigator.serviceWorker.getRegistration().then((reg) => {
              if (!reg || !reg.waiting) return location.reload();
              reg.waiting.postMessage({ type: 'SKIP_WAITING' });
              reg.waiting.addEventListener('statechange', (e) => {
                const st = e && e.target && (e.target as any).state ? (e.target as any).state : null;
                if (st === 'activated') location.reload();
              });
            });
          });
        }
        if (dismissBtn) dismissBtn.addEventListener('click', () => el.remove());
      }
    </script>
  </body>
</html>
