---
import "../styles/global.css";
import Snipcart from "../components/Snipcart.astro";
import artFiltersScript from "../scripts/artFilters.js?url";
import shopFiltersScript from "../scripts/shopFilters.js?url";
import preorderLightboxScript from "../scripts/preorderLightbox.js?url";
import snipcartCheckoutScript from "../scripts/snipcartCheckout.js?url";
import legacyServiceWorkerCleanupScript from "../scripts/legacyServiceWorkerCleanup.js?url";
import newsletterFormScript from "../scripts/newsletterForm.js?url";
const {
  title = "Tommy Day",
  description = "Analog collage, prints, cards, and strange paper goods by Tommy Day.",
  ogImage,
  ogType = "website",
  canonicalUrl,
  canonical,
  robots = "index,follow",
} = Astro.props;

const siteOrigin = "https://tommyday.com";
const resolvedCanonical = canonicalUrl || canonical;
const canonicalHref = resolvedCanonical
  ? new URL(resolvedCanonical, siteOrigin).href
  : undefined;
const ogImageHref = ogImage ? new URL(ogImage, siteOrigin).href : undefined;
const siteSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "url": siteOrigin,
      "name": "Tommy Day Art",
      "description": description
    },
    {
      "@type": "Person",
      "name": "Tommy Day",
      "url": siteOrigin,
      "sameAs": ["https://www.instagram.com/tommyday"]
    }
  ]
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonicalHref ? <link rel="canonical" href={canonicalHref} /> : null}
  <meta name="robots" content={robots} />
  <meta name="theme-color" content="#fff12f" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Tommy Day Art" />
  {canonicalHref ? <meta property="og:url" content={canonicalHref} /> : null}
  {ogImageHref ? <meta property="og:image" content={ogImageHref} /> : null}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImageHref ? <meta name="twitter:image" content={ogImageHref} /> : null}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,600;1,400&family=Special+Elite&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
  <script src="https://kit.fontawesome.com/f0d3128641.js" crossorigin="anonymous"></script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-9V2CC0M35T"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){window.dataLayer.push(arguments);}
    window.gtag = gtag;
    gtag('js', new Date());
    gtag('config', 'G-9V2CC0M35T');
  </script>
    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
    <link rel="icon" href="/favicon.svg" />
    <script type="module" src={artFiltersScript}></script>
    <script type="module" src={shopFiltersScript}></script>
    <script type="module" src={preorderLightboxScript}></script>
    <script type="module" src={snipcartCheckoutScript}></script>
    <script type="module" src={newsletterFormScript}></script>
    <Snipcart />
  </head>
  <body class="bg-stone-100 text-neutral-950 antialiased">
    <slot />
    <script type="module" src={legacyServiceWorkerCleanupScript}></script>
  </body>
</html>
