---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/SiteShell.astro";
---

<BaseLayout
  title="Privacy Policy — Tommy Day Art"
  description="Privacy policy for Tommy Day Art, including checkout, email, analytics, and contact information."
  canonicalUrl="/privacy/"
>
  <SiteShell>
    <section class="page-intro-copy">
      <p class="section-eyebrow">Shop policies</p>
      <h1 class="text-2xl font-serif">Privacy Policy</h1>
      <p>
        This site collects only the information needed to run the shop, respond to messages, and
        fulfill orders.
      </p>

      <h2>Orders and checkout</h2>
      <p>
        Checkout is handled by Snipcart and its payment providers. Information entered at checkout
        may include your name, email address, shipping address, billing details, and order contents.
        Payment details are processed by the checkout provider and are not stored directly by Tommy
        Day Art.
      </p>

      <h2>Contact</h2>
      <p>
        If you email or contact Tommy Day Art, your message and contact information are used to
        respond to that conversation.
      </p>

      <h2>Cookies and local storage</h2>
      <p>
        The cart and checkout may use cookies or local storage to keep track of cart contents and
        checkout state. The site may also use basic browser storage for performance and navigation.
      </p>

      <h2>Analytics</h2>
      <p>
        This site uses Google Analytics to understand site traffic and improve the shop. Google may
        collect information such as page views, browser/device details, and general location derived
        from your connection. You can use browser settings or privacy tools to limit analytics
        tracking.
      </p>

      <h2>Questions</h2>
      <p>
        For privacy questions or order help, email
        <a href="mailto:hey@tommyday.com">hey@tommyday.com</a>.
      </p>
    </section>
  </SiteShell>
</BaseLayout>
