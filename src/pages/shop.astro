---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/SiteShell.astro";
import ShopCard from "../components/ShopCard.astro";
import { getLowestAvailablePrice } from "../data/artworkHelpers";
import { shopArtworks } from "../data/artworks";
import { launchPreorderProducts } from "../data/preorderProducts";

const preorderCount = launchPreorderProducts.length;
---

<BaseLayout
  title="Shop Collage Prints, Cards, and Originals — Tommy Day"
  description="Shop available analog collage work, small-batch prints, greeting cards, bookmarks, and original pieces by Tommy Day."
  canonicalUrl="/shop/"
>
  <SiteShell>
    <section class="shop-hero">
      <div class="shop-hero__copy">
        <h1 class="shop-hero__title">Shop</h1>
        <p class="shop-hero__description">
          Original analog collage, small-batch prints, greeting cards, and paper goods made by hand in Indianapolis, Indiana.
        </p>
        <p class="shop-hero__trust">Ships from Indianapolis * Packed flat</p>
      </div>

      <div class="shop-hero__visual" aria-hidden="true">
        <div class="shop-hero__visual-card">
          <span>Future shop scan</span>
        </div>
      </div>
    </section>

    <div x-data="shopFilters()">
      <div class="shop-action-strip">
        <div class="shop-action-strip__filters">
          <div class="shop-filter-panel">
            <div class="shop-filter-panel__row">
              <span class="shop-filter-panel__label">Show me</span>
              <div class="shop-segmented" role="tablist" aria-label="Shop base filter">
                <button
                  type="button"
                  class="shop-segmented__button"
                  :class="{ 'is-active': selectedBase === 'all' }"
                  @click="setBase('all')"
                >
                  All available
                </button>
                <button
                  type="button"
                  class="shop-segmented__button"
                  :class="{ 'is-active': selectedBase === 'original' }"
                  @click="setBase('original')"
                >
                  Originals
                </button>
                <button
                  type="button"
                  class="shop-segmented__button"
                  :class="{ 'is-active': selectedBase === 'print' }"
                  @click="setBase('print')"
                >
                  Prints
                </button>
              </div>
            </div>

            <div class="shop-filter-panel__row">
              <span class="shop-filter-panel__label">Narrow by</span>
              <div class="shop-toggle-list">
                <button
                  type="button"
                  class="shop-toggle-button"
                  :class="{ 'is-active': isActive('under25') }"
                  @click="toggleFilter('under25')"
                >
                  Under $25
                </button>
                <button
                  type="button"
                  class="shop-toggle-button"
                  :class="{ 'is-active': isActive('size9x12') }"
                  @click="toggleFilter('size9x12')"
                >
                  9x12
                </button>
                <button
                  type="button"
                  class="shop-toggle-button"
                  :class="{ 'is-active': isActive('size11x14') }"
                  @click="toggleFilter('size11x14')"
                >
                  11x14
                </button>
                <button
                  type="button"
                  class="shop-toggle-button"
                  :class="{ 'is-active': isActive('size425x55') }"
                  @click="toggleFilter('size425x55')"
                >
                  4.25x5.5
                </button>
              </div>
              <button
                x-show="hasActiveFilters()"
                @click="clearFilters()"
                class="shop-filter-panel__clear"
                type="button"
              >
                Clear
              </button>
            </div>

            <p
              class="shop-filter-panel__count"
              aria-live="polite"
              x-text="resultLabel()"
            ></p>
          </div>
        </div>

        <section class="shop-preorder" aria-labelledby="shop-preorder-heading">
          <div class="shop-preorder__header">
            <p class="shop-preorder__kicker">Pre-order window</p>
            <h2 id="shop-preorder-heading">Pre-orders</h2>
            <p>
              There is a Pre-Order window open now that ends on June 10! Every order includes a free 5x7 print!
            </p>
            <a href="/pre-order/" class="shop-preorder__link">Learn More</a>
          </div>
        </section>
      </div>

      <div class="shop-grid">
        {shopArtworks.map((art) => {
          const availableProducts = art.products.filter((product) => product.status === "available");
          const availableAs = availableProducts
            .map((product) => product.type)
            .filter((value, index, array) => array.indexOf(value) === index)
            .join(",");
          const sizeTags = availableProducts
            .map((product) => {
              if (product.type === "original") return art.dimensions;
              if (product.label.includes("8x10")) return "8x10";
              if (product.label.includes("5x7")) return "5x7";
              if (product.label.includes("9x12")) return "9x12";
              if (product.label.includes("11x14")) return "11x14";
              return null;
            })
            .filter((value, index, array) => value && array.indexOf(value) === index)
            .join(",");
          const lowestPrice = getLowestAvailablePrice(art);

          return (
            <div
              data-available-as={availableAs}
              data-size-tags={sizeTags}
              data-under-25={lowestPrice !== null && lowestPrice <= 25 ? "true" : "false"}
              data-shop-item
              x-show="matches($el) && isVisible($el)"
              x-cloak
              class="h-full"
            >
              <ShopCard artwork={art} />
            </div>
          );
        })}
      </div>

      <div class="shop-load-more" x-show="hasMore()" x-cloak>
        <button
          type="button"
          class="shop-load-more__button"
          @click="loadMore()"
          x-text="`Load ${Math.min(pageSize, remainingCount())} more`"
        >
          Load 9 more
        </button>
      </div>
    </div>
  </SiteShell>
</BaseLayout>
