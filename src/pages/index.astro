---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/SiteShell.astro";
import ArtCard from "../components/ArtCard.astro";
import { featuredArtworks } from "../data/artworks";

const shuffled = featuredArtworks.slice().sort(() => Math.random() - 0.5);
const show = shuffled.slice(0, 3);
const heroArt = featuredArtworks.slice(0, 3);
---
<BaseLayout title="Tommy Day — Collage, music, and video" description="Collage, music, and video by Tommy Day." canonical="/">
  <SiteShell>
    <section class="home-hero">
      <div class="home-hero__intro">
        <p class="hero-kicker">Artist hub</p>
        <h1 class="home-hero__title">Collage, music, and video.</h1>
        <p class="home-hero__lede">
          Analog collage, songs, and moving pictures gathered into one place now that the work side of life is moving over to WPIndy.
        </p>

        <div class="home-hero__actions">
          <a href="/collage/" class="hero-link">Browse collage work</a>
          <a href="/music/" class="hero-link">Hear the music</a>
        </div>
      </div>

      <div class="home-hero__art" aria-hidden="true">
        {heroArt.map((art, index) => (
          <figure class={`hero-scrap hero-scrap--${index + 1}`}>
            <img src={art.thumbnail || art.image} alt="" loading="eager" />
          </figure>
        ))}
      </div>
    </section>

    <section class="mt-12">
      <div class="section-head">
        <h2 class="section-title">Featured collage</h2>
        <a href="/collage/" class="section-link">View full collage portfolio</a>
      </div>

      <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 items-stretch">
      {show.map((art) => (
        <div class="h-full">
          <ArtCard artwork={art} compact={true} />
        </div>
      ))}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="font-semibold">Music</h2>
      <p class="text-neutral-700 mt-2">Songs, side projects, Secret Oats with Jay Adams, and a place for clips and recordings to live together.</p>
      <div class="mt-3 flex gap-3">
        <a class="px-3 py-2 border" href="/music/">Music page</a>
        <a class="px-3 py-2 border" href="/video/">Video work</a>
        <a class="px-3 py-2 border" href="/blog/">Blog</a>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="font-semibold">Contact</h2>
      <p class="text-neutral-700 mt-2">For art, music, booking, commissions, or weird opportunities: <a class="underline" href="mailto:hey@tommyday.com">hey@tommyday.com</a></p>
    </section>
  </SiteShell>
</BaseLayout>
