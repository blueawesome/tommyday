---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/SiteShell.astro";
import ArtCard from "../components/ArtCard.astro";
import { featuredArtworks } from "../data/artworks";

const featured = featuredArtworks.slice(0, 9);
---
<BaseLayout
  title="Tommy Day Art - Analog Collage, Prints, Cards, and Paper Goods"
  description="Analog collage, prints, cards, and strange paper goods by Tommy Day."
  canonicalUrl="/"
>
  <SiteShell>
    <section class="home-brand-hero">
      <div class="home-brand-hero__top">
        <picture>
          <source media="(min-width: 720px)" srcset="/images/tommy-day-art.png" />
          <img
            src="/images/tommy-day-art-small.png"
            alt="Tommy Day Art"
            class="home-brand-hero__logo"
            loading="eager"
          />
        </picture>
      </div>

      <div class="home-brand-hero__copy">
        <p class="home-brand-hero__line">Hand-Cut Analog Collage</p>
        <p>
          Cut from old magazines, books, ads, catalogs, and whatever else looks like it has
          unfinished business. Handmade analog collage using vintage paper, available as originals,
          prints, cards, and small-batch paper goods.
        </p>
      </div>

      <div class="home-brand-hero__actions">
        <a href="/pre-order/" class="hero-link hero-link--primary">Pre-Order Prints & Cards</a>
        <a href="/collage/" class="hero-link">Browse Collage Work</a>
      </div>
    </section>

    <section class="home-featured" aria-labelledby="home-featured-heading">
      <div class="home-featured__header">
        <p class="section-eyebrow">Featured collage</p>
        <h1 id="home-featured-heading" class="home-featured__title">Recent cuts from the archive</h1>
        <p>
          A small window into the collage work. The full archive has more originals, experiments,
          and pieces that may become prints or cards.
        </p>
        <a href="/collage/" class="section-link">View full collage archive</a>
      </div>

      <div class="home-featured-carousel" aria-label="Featured collage carousel">
        <button
          class="home-featured-carousel__control home-featured-carousel__control--prev"
          type="button"
          aria-label="Scroll featured collage left"
          onclick="this.closest('.home-featured-carousel').querySelector('.home-featured-carousel__track').scrollBy({ left: -420, behavior: 'smooth' })"
        >
          <span aria-hidden="true">←</span>
        </button>
        <div class="home-featured-carousel__track" tabindex="0">
          {featured.map((art) => (
            <div class="home-featured-carousel__slide">
              <ArtCard artwork={art} compact={true} />
            </div>
          ))}
        </div>
        <button
          class="home-featured-carousel__control home-featured-carousel__control--next"
          type="button"
          aria-label="Scroll featured collage right"
          onclick="this.closest('.home-featured-carousel').querySelector('.home-featured-carousel__track').scrollBy({ left: 420, behavior: 'smooth' })"
        >
          <span aria-hidden="true">→</span>
        </button>
      </div>
    </section>
  </SiteShell>
</BaseLayout>
