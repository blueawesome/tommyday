---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/SiteShell.astro";
---

<BaseLayout
  title="Thank You — Tommy Day Art"
  description="Thank you for ordering from Tommy Day Art."
  canonicalUrl="/thank-you/"
  robots="noindex,follow"
>
  <SiteShell>
    <section class="page-intro-copy thank-you-page">
      <p class="section-eyebrow">Order received</p>
      <h1 class="text-2xl font-serif">Thank you</h1>
      <p>
        Your order is in. A confirmation email from Snipcart should arrive shortly with your order
        details.
      </p>

      <h2>What happens next?</h2>
      <p>
        Preorder items are produced after the preorder window closes and are expected to ship in
        late June. Available originals and shop items ship from Indianapolis, packed flat with care.
      </p>

      <h2>Need anything?</h2>
      <p>
        If you need to update an address, ask a question, or coordinate a local handoff, email
        <a href="mailto:hey@tommyday.com">hey@tommyday.com</a>.
      </p>

      <div class="thank-you-page__actions" aria-label="After order links">
        <a href="/pre-order/" class="hero-link hero-link--primary">Back to pre-orders</a>
        <a href="/collage/" class="hero-link">Browse collage work</a>
      </div>
    </section>
  </SiteShell>
</BaseLayout>
