---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/SiteShell.astro";
import PreorderProductCard from "../components/PreorderProductCard.astro";
import {
  launchPreorder,
  launchPreorderProducts,
  launchPreorderCardPacks,
  launchPreorderPrints,
} from "../data/preorderProducts";

const preorderCloseDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(new Date(`${launchPreorder.closesAt}T00:00:00`));

const preorderItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Tommy Day Art launch preorder",
  "itemListElement": launchPreorderProducts.map((product, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": {
      "@type": "Product",
      "name": product.snipcartName || product.title,
      "description": product.snipcartDescription || product.description,
      "image": new URL(product.image, "https://tommyday.com").href,
      "brand": {
        "@type": "Brand",
        "name": "Tommy Day Art"
      },
      "offers": {
        "@type": "Offer",
        "price": product.price,
        "priceCurrency": "USD",
        "availability": "https://schema.org/PreOrder",
        "url": "https://tommyday.com/pre-order/",
        "availabilityStarts": launchPreorder.openedAt,
        "availabilityEnds": launchPreorder.closesAt
      }
    }
  }))
};
---

<BaseLayout
  title="Pre-Order Prints & Cards - Tommy Day"
  description="Pre-order signed Tommy Day Art prints and greeting cards from the initial small print run."
  canonicalUrl="/pre-order/"
>
  <SiteShell>
    <script type="application/ld+json" set:html={JSON.stringify(preorderItemListSchema)} />

    <section class="preorder-hero">
      <div class="preorder-hero__copy">
        <p class="section-eyebrow">Launch preorder</p>
        <h1 class="preorder-hero__title">Pre-Order Prints & Cards</h1>
        <div class="preorder-hero__text">
          <p>
            A short launch preorder for the first small run of Tommy Day Art prints, cards, and
            weird paper goods.
          </p>
          <p>
            Preorders close June 10. Orders are expected to ship in late June.
          </p>
          <p>
            Every preorder print includes one free random 5x7 print on thick cardstock.
          </p>
        </div>
      </div>

      <div class="preorder-hero__side">
        <div class="preorder-hero__stamp" aria-label={`Preorder closes ${preorderCloseDate}`}>
          <span>Preorder closes</span>
          <strong>{preorderCloseDate}</strong>
        </div>
      </div>
    </section>

    <section class="preorder-section preorder-section--prints" aria-labelledby="preorder-prints">
      <div class="preorder-section__header">
        <p class="section-eyebrow">Signed preorder prints</p>
        <h2 id="preorder-prints">Signed Preorder Prints</h2>
        <p>Archival quality signed prints. Each one includes a free random 5x7 print on thick cardstock.</p>
      </div>

      <div class="preorder-carousel" aria-label="Signed preorder print carousel">
        <button
          class="preorder-carousel__control preorder-carousel__control--prev"
          type="button"
          aria-label="Scroll preorder prints left"
          onclick="this.closest('.preorder-carousel').querySelector('.preorder-carousel__track').scrollBy({ left: -420, behavior: 'smooth' })"
        >
          <span aria-hidden="true">←</span>
        </button>
        <div class="preorder-carousel__track" tabindex="0">
          {launchPreorderPrints.map((product) => (
            <div class="preorder-carousel__slide">
              <PreorderProductCard product={product} />
            </div>
          ))}
        </div>
        <button
          class="preorder-carousel__control preorder-carousel__control--next"
          type="button"
          aria-label="Scroll preorder prints right"
          onclick="this.closest('.preorder-carousel').querySelector('.preorder-carousel__track').scrollBy({ left: 420, behavior: 'smooth' })"
        >
          <span aria-hidden="true">→</span>
        </button>
      </div>

      <aside class="preorder-social-note" aria-label="Instagram preorder updates">
        <p class="preorder-social-note__label">Follow along</p>
        <p>
          Follow
          <a href="https://www.instagram.com/tommyday" target="_blank" rel="noopener noreferrer">@TommyDay</a>
          on Instagram for process videos, closeups, and preorder updates.
        </p>
      </aside>
    </section>

    <div class="preorder-secondary-sections preorder-secondary-sections--single">
      <section class="preorder-section" aria-labelledby="preorder-cards">
        <div class="preorder-section__header">
          <p class="section-eyebrow">Folded cards</p>
          <h2 id="preorder-cards">Greeting Card Pack</h2>
          <p>A2 folded cards, blank inside, with envelopes included.</p>
        </div>

        <div class="preorder-grid preorder-grid--single">
          {launchPreorderCardPacks.map((product) => (
            <PreorderProductCard product={product} />
          ))}
        </div>
      </section>

    </div>

    <section class="preorder-faq" aria-labelledby="preorder-faq">
      <div class="preorder-section__header">
        <p class="section-eyebrow">Tiny FAQ</p>
        <h2 id="preorder-faq">Preorder FAQ</h2>
      </div>

      <div class="preorder-faq__grid">
        <div>
          <h3>Is this a preorder?</h3>
          <p>Yes. These items are ordered now and produced after the preorder window closes.</p>
        </div>
        <div>
          <h3>When will my order ship?</h3>
          <p>
            Orders are expected to ship around {launchPreorder.estimatedShipDate}. I'll send an
            update if timing changes.
          </p>
        </div>
        <div>
          <h3>How much is shipping?</h3>
          <p>
            Standard U.S. shipping is $7.95. Orders over $50 ship free. Local handoff is available
            for people I know in real life.
          </p>
        </div>
        <div>
          <h3>What is the free random 5x7 print?</h3>
          <p>
            It's a free random 5x7 print on thick cardstock, selected from a separate launch batch.
            You don't need to pick a design.
          </p>
        </div>
        <div>
          <h3>Are the prints signed?</h3>
          <p>Yes, preorder prints are signed unless a product specifically says otherwise.</p>
        </div>
        <div>
          <h3>Are these limited editions?</h3>
          <p>
            This is a signed preorder batch, not necessarily a permanently limited edition unless a
            product specifically says so.
          </p>
        </div>
        <div>
          <h3>Can I order regular shop items with preorder items?</h3>
          <p>
            For launch, preorder items should be treated as shipping together when the preorder
            batch is ready.
          </p>
        </div>
      </div>
    </section>

    <dialog class="preorder-lightbox" id="preorder-lightbox" aria-labelledby="preorder-lightbox-title">
      <div class="preorder-lightbox__panel">
        <button class="preorder-lightbox__close" type="button" data-preorder-lightbox-close>
          Close
        </button>
        <figure class="preorder-lightbox__figure">
          <img src="" alt="" class="preorder-lightbox__image" data-preorder-lightbox-image />
          <figcaption class="preorder-lightbox__caption" id="preorder-lightbox-title" data-preorder-lightbox-caption></figcaption>
        </figure>
      </div>
    </dialog>
  </SiteShell>
</BaseLayout>
