---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteShell from "../../components/SiteShell.astro";
import ArtworkPurchaseOptions from "../../components/ArtworkPurchaseOptions.astro";
import { publishedArtworks } from "../../data/artworks";
import { getAvailabilityLabel } from "../../data/artworkHelpers";

export async function getStaticPaths() {
  return publishedArtworks.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const artwork = publishedArtworks.find((a) => a.slug === slug);

if (!artwork) {
  throw new Error(`Artwork not found: ${slug}`);
}
---

<BaseLayout title={`${artwork.title}`} description={artwork.description || 'Analog collage, songs, videos, and handmade work by Tommy Day.'} ogImage={artwork.image}>
  <SiteShell>
    <a class="text-sm underline" href="/collage/">← Back to collage</a>

    <div class="mt-4 grid gap-8 md:grid-cols-2">
      <div>
        <img src={artwork.image} alt={artwork.alt} class="w-full bg-white shadow-sm" />
      </div>

      <div>
  <h1 class="text-2xl font-serif">{artwork.title}</h1>
  <div class="text-neutral-700 mt-2">{artwork.dimensions ? `${artwork.dimensions} · ` : ''}{artwork.year}</div>

        <div class="mt-4 text-sm text-neutral-600">{getAvailabilityLabel(artwork)}</div>

        {artwork.description ? <p class="mt-4">{artwork.description}</p> : null}

        <ArtworkPurchaseOptions artwork={artwork} />
      </div>
    </div>
  </SiteShell>
</BaseLayout>
