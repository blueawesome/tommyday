---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteShell from "../../components/SiteShell.astro";
import ArtworkPurchaseOptions from "../../components/ArtworkPurchaseOptions.astro";
import { publishedArtworks } from "../../data/artworks";
import {
  getDetailPageDescription,
  getAvailableProducts,
  hasAvailableProducts,
} from "../../data/artworkHelpers";

export async function getStaticPaths() {
  return publishedArtworks.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const artwork = publishedArtworks.find((a) => a.slug === slug);

if (!artwork) {
  throw new Error(`Artwork not found: ${slug}`);
}

const fallbackImage = {
  id: "artwork",
  src: artwork.image,
  alt: artwork.alt,
  label: "Artwork",
  type: "artwork",
};
const detailImages = artwork.galleryImages?.length ? artwork.galleryImages : [fallbackImage];
const galleryState = `{
  images: ${JSON.stringify(detailImages)},
  activeImage: ${JSON.stringify(detailImages[0])},
  previousImage: null,
  isTransitioning: false,
  transitionTimer: null,
  selectImage(image) {
    if (!image || image.id === this.activeImage.id) return;
    this.previousImage = this.activeImage;
    this.activeImage = image;
    this.isTransitioning = true;
    window.clearTimeout(this.transitionTimer);
    this.transitionTimer = window.setTimeout(() => {
      this.isTransitioning = false;
      window.setTimeout(() => {
        if (!this.isTransitioning) this.previousImage = null;
      }, 340);
    }, 30);
  },
  selectImageById(id) {
    if (!id) return;
    const image = this.images.find((item) => item.id === id);
    if (image) this.selectImage(image);
  }
}`;
const availableProducts = getAvailableProducts(artwork);
const isSecretArtwork = artwork.showInGallery === false && artwork.showInShop === false;
const pricedAvailableProducts = availableProducts.filter(
  (product) => typeof product.price === "number"
);
const artworkSchema = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  "name": artwork.title,
  "creator": {
    "@type": "Person",
    "name": "Tommy Day"
  },
  "artMedium": artwork.medium,
  "dateCreated": artwork.year,
  "image": new URL(artwork.image, "https://tommyday.com").href,
  "url": `https://tommyday.com/collage/${artwork.slug}/`,
  ...(artwork.series ? {
    "isPartOf": {
      "@type": "CreativeWorkSeries",
      "name": artwork.series.name,
      ...(artwork.series.description ? { "description": artwork.series.description } : {})
    }
  } : {}),
  ...(artwork.description ? { "description": artwork.description } : {}),
  ...(pricedAvailableProducts.length
    ? {
        "offers": pricedAvailableProducts.map((product) => ({
            "@type": "Offer",
            "name": product.label,
            "price": product.price,
            "priceCurrency": "USD",
            "availability": "https://schema.org/InStock",
            "url": `https://tommyday.com/collage/${artwork.slug}/`
          }))
      }
    : {})
};
---

<BaseLayout
  title={`${artwork.title} — Analog Collage by Tommy Day`}
  description={getDetailPageDescription(artwork)}
  ogImage={artwork.image}
  canonicalUrl={`/collage/${artwork.slug}/`}
  robots={isSecretArtwork ? "noindex,follow" : "index,follow"}
>
  <SiteShell>
    <script type="application/ld+json" set:html={JSON.stringify(artworkSchema)} />

    <div class="detail-top-links">
      <nav class="detail-breadcrumb" aria-label="Breadcrumb">
        <a href="/collage/">Collage</a>
        <span aria-hidden="true">/</span>
        <span>{artwork.title}</span>
      </nav>
      {hasAvailableProducts(artwork) && artwork.showInShop !== false ? (
        <a class="detail-shop-link" href="/shop/">Shop Available Work</a>
      ) : null}
    </div>

    <div class="mt-4 grid gap-8 md:grid-cols-2" x-data={galleryState}>
      <div class="detail-media">
        <div class="detail-image-frame">
          <img
            src={artwork.image}
            alt=""
            class="detail-image detail-image--previous"
            x-bind:src="previousImage ? previousImage.src : activeImage.src"
            x-bind:alt="previousImage ? previousImage.alt : ''"
            x-bind:class="{ 'is-visible': previousImage && isTransitioning }"
            aria-hidden="true"
          />
          <img
            src={artwork.image}
            alt={artwork.alt}
            class="detail-image detail-image--active"
            x-bind:src="activeImage.src"
            x-bind:alt="activeImage.alt"
            x-bind:class="{ 'is-entering': isTransitioning }"
          />
        </div>

        {detailImages.length > 1 ? (
          <div class="detail-gallery-strip" aria-label="Artwork image gallery">
            {detailImages.map((image) => (
              <button
                type="button"
                class="detail-gallery-thumb"
                x-bind:class={`activeImage.id === ${JSON.stringify(image.id)} ? 'is-active' : ''`}
                @click={`selectImage(${JSON.stringify(image)})`}
                aria-label={image.label ? `Show ${image.label}` : "Show artwork image"}
              >
                <img src={image.src} alt="" loading="lazy" />
                {image.label ? <span>{image.label}</span> : null}
              </button>
            ))}
          </div>
        ) : null}
      </div>

      <div>
        <h1 class="text-2xl font-serif">{artwork.title}</h1>
        {artwork.series ? (
          <div class="detail-title-badges" aria-label="Artwork series">
            <span class="detail-series-badge">{artwork.series.name} Series</span>
          </div>
        ) : null}
        <div class="detail-meta-line">
          {artwork.medium}{artwork.dimensions ? ` · ${artwork.dimensions}` : ""} · {artwork.year}
        </div>

        {artwork.description ? <p class="mt-4">{artwork.description}</p> : null}

        <div class="mt-6">
          <h2 class="font-semibold text-xl">Available As</h2>
          <ArtworkPurchaseOptions artwork={artwork} />
        </div>
      </div>
    </div>
  </SiteShell>
</BaseLayout>
