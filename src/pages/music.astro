---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/SiteShell.astro";
import PageHeader from "../components/PageHeader.astro";
import MediaEmbedCard from "../components/MediaEmbedCard.astro";
import { musicPage } from "../data/siteContent";
---
<BaseLayout
  title="Music — Tommy Day"
  description={musicPage.description}
  canonicalUrl="/music/"
  robots="noindex,follow"
>
  <SiteShell>
    <PageHeader
      title={musicPage.title}
      kicker={musicPage.kicker}
      description={musicPage.description}
      visualItems={musicPage.visualItems}
      actions={musicPage.actions}
    />

    <section class="page-intro-copy">
      <p>{musicPage.intro}</p>
    </section>

    <div class="content-stack">
      {musicPage.sections.map((section) => (
        <section class="editorial-block">
          <div class="editorial-block__copy">
            <h2>{section.title}</h2>
            <p>{section.body}</p>

            {section.links && section.links.length > 0 ? (
              <div class="editorial-block__links">
                {section.links.map((link) => (
                  <a
                    href={link.href}
                    class="media-card__link"
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            ) : null}
          </div>

          {section.embeds && section.embeds.length > 0 ? (
            <div class="editorial-block__media">
              {section.embeds.map((embed) => (
                <MediaEmbedCard item={embed} />
              ))}
            </div>
          ) : null}
        </section>
      ))}
    </div>
  </SiteShell>
</BaseLayout>
