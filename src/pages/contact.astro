---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/SiteShell.astro";
---
<BaseLayout
  title="Contact — Tommy Day"
  description="Contact Tommy Day about collage work, available pieces, orders, commissions, and other opportunities."
  canonicalUrl="/contact/"
>
  <SiteShell>
    <h1 class="text-2xl font-serif">Contact</h1>
    <p class="mt-4 text-neutral-700">For art, available work, orders, commissions, or weird opportunities:</p>
    <p class="mt-2"><a class="underline" href="mailto:hey@tommyday.com">hey@tommyday.com</a></p>
  </SiteShell>
</BaseLayout>
