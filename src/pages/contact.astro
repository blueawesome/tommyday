---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/SiteShell.astro";
import contactFormScript from "../scripts/contactForm.js?url";

const showContactForm = true;
---
<BaseLayout
  title="Contact — Tommy Day"
  description="Contact Tommy Day about collage work, available pieces, orders, commissions, and other opportunities."
  canonicalUrl="/contact/"
>
  <SiteShell>
    <section class="contact-page" aria-labelledby="contact-heading">
      <div class="contact-page__intro">
        <p class="section-eyebrow">Say hey</p>
        <h1 id="contact-heading">Contact</h1>
        <p>
          Have a question about a piece, want to chat about a project, or just want to say hello? Feel free to use the form below or send me a note.
          <a href="mailto:hey@tommyday.com">hey@tommyday.com</a>.
        </p>
       
      </div>

      {showContactForm && (
        <form class="contact-form" action="/api/contact" method="post" data-contact-form>
          <div class="contact-form__honeypot" hidden>
            <label for="contact-website">Website</label>
            <input id="contact-website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <label class="contact-form__field" for="contact-name">
            <span>Name</span>
            <input id="contact-name" name="name" type="text" autocomplete="name" required />
          </label>

          <label class="contact-form__field" for="contact-email">
            <span>Email</span>
            <input id="contact-email" name="email" type="email" autocomplete="email" required />
          </label>

          <label class="contact-form__field" for="contact-subject">
            <span>What is this about?</span>
            <select id="contact-subject" name="subject">
              <option value="Artwork question">Artwork question</option>
              <option value="Order or shipping question">Order or shipping question</option>
              <option value="Commission or project">Commission or project</option>
              <option value="Something else">Something else</option>
            </select>
          </label>

          <label class="contact-form__field contact-form__field--full" for="contact-message">
            <span>Message</span>
            <textarea id="contact-message" name="message" rows="6" required></textarea>
          </label>

          <div class="contact-form__actions">
            <button class="contact-form__button" type="submit">Send note</button>
            <p class="contact-form__status" data-contact-status aria-live="polite"></p>
          </div>
        </form>
      )}
    </section>
  </SiteShell>
  {showContactForm && <script type="module" src={contactFormScript}></script>}
</BaseLayout>
