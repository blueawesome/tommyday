---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteShell from "../components/SiteShell.astro";
import ArtCard from "../components/ArtCard.astro";
import { artworkSeries, galleryArtworks } from "../data/artworks";
import {
  getArtworkScopeStatus,
  hasAvailableProductType,
} from "../data/artworkHelpers";
---
<BaseLayout
  title="Analog Collage by Tommy Day"
  description="Analog collage archive by Tommy Day, including sold work, available originals, prints, cards, and archive-only pieces."
  canonicalUrl="/collage/"
>
  <SiteShell>
    <section class="collage-hero">
      <div class="collage-hero__copy">
        <p class="section-eyebrow">Analog collage archive</p>
        <h1 class="collage-hero__title">Collage</h1>
        <p>
          Cut from old magazines, books, ads, packaging, and whatever else survives the scissors.
          This archive includes available work, sold originals, studies, and pieces that may become
          prints or cards.
        </p>
      </div>

      <div class="collage-hero__visual" aria-hidden="true">
        <div class="collage-hero__visual-card">
          <span>Future scissors portrait</span>
        </div>
      </div>
    </section>

    <div x-data="artFilters()" class="collage-archive">
      <div class="collage-filter-panel">
        <div class="collage-filter-panel__row">
          <span class="collage-filter-panel__label">Show me</span>
          <div class="collage-filter-panel__buttons" role="group" aria-label="Archive scope">
            <button
              type="button"
              class="collage-filter-button"
              :class="{ 'is-active': scope === 'all' }"
              @click="setScope('all')"
            >
              All work
            </button>
            <button
              type="button"
              class="collage-filter-button"
              :class="{ 'is-active': scope === 'available' }"
              @click="setScope('available')"
            >
              Work for sale
            </button>
            <button
              type="button"
              class="collage-filter-button"
              :class="{ 'is-active': scope === 'sold' }"
              @click="setScope('sold')"
            >
              Sold pieces
            </button>
          </div>
        </div>

        <div class="collage-filter-panel__row" x-show="scope === 'available'" x-cloak>
          <span class="collage-filter-panel__label">Available as</span>
          <div class="collage-filter-panel__buttons" role="group" aria-label="Available format">
            <button
              type="button"
              class="collage-filter-button"
              :class="{ 'is-active': selectedFormat === 'any' }"
              @click="setFormat('any')"
            >
              Anything
            </button>
            <button
              type="button"
              class="collage-filter-button"
              :class="{ 'is-active': selectedFormat === 'original' }"
              @click="setFormat('original')"
            >
              Originals
            </button>
            <button
              type="button"
              class="collage-filter-button"
              :class="{ 'is-active': selectedFormat === 'print' }"
              @click="setFormat('print')"
            >
              Prints
            </button>
            <button
              type="button"
              class="collage-filter-button"
              :class="{ 'is-active': selectedFormat === 'card' }"
              @click="setFormat('card')"
            >
              Cards
            </button>
            <button
              type="button"
              class="collage-filter-button"
              :class="{ 'is-active': selectedFormat === 'bookmark' }"
              @click="setFormat('bookmark')"
            >
              Bookmarks
            </button>
          </div>
        </div>

        <div class="collage-filter-panel__row">
          <span class="collage-filter-panel__label">Series</span>
          <div class="collage-filter-panel__buttons" role="group" aria-label="Artwork series">
            <button
              type="button"
              class="collage-filter-button"
              :class="{ 'is-active': selectedSeries === 'all' }"
              @click="setSeries('all')"
            >
              All series
            </button>
            <button
              type="button"
              class="collage-filter-button"
              :class="{ 'is-active': selectedSeries === 'minimal-cut-study' }"
              @click="setSeries('minimal-cut-study')"
            >
              {artworkSeries.minimalCutStudy.name}
            </button>
          </div>
        </div>

        <div class="collage-filter-panel__footer">
          <p class="collage-filter-panel__count" aria-live="polite" x-text="resultLabel()"></p>
          <button
            x-show="hasActiveFilters()"
            x-cloak
            @click="clearFilters()"
            class="collage-filter-panel__clear"
            type="button"
          >
            Clear filters
          </button>
        </div>
      </div>

      <div class="archive-columns">
        {galleryArtworks.map((art, i) => {
          const status = getArtworkScopeStatus(art);
          const availableAs = [
            hasAvailableProductType(art, "original") ? "original" : null,
            hasAvailableProductType(art, "print") ? "print" : null,
            hasAvailableProductType(art, "card") ? "card" : null,
            hasAvailableProductType(art, "bookmark") ? "bookmark" : null,
          ]
            .filter(Boolean)
            .join(",");

          return (
            <div
              class:list={["archive-item", `archive-item--tilt-${(i % 5) + 1}`]}
              :style={`transitionDelay: calc(var(--stagger-step) * ${i})`}
              data-status={status}
              data-available-as={availableAs}
              data-sizes={art.filters && art.filters.sizes ? art.filters.sizes.join(',') : ''}
              data-series={art.filters && art.filters.series ? art.filters.series.join(',') : ''}
              data-archive-item
              x-show="matches($el)"
              x-cloak
              x-transition:enter="alpine-enter"
              x-transition:enter-start="alpine-enter-start"
              x-transition:enter-end="alpine-enter-end"
              x-transition:leave="alpine-leave"
              x-transition:leave-start="alpine-leave-start"
              x-transition:leave-end="alpine-leave-end"
            >
              <ArtCard artwork={art} />
            </div>
          );
        })}
      </div>
    </div>
  </SiteShell>
</BaseLayout>
